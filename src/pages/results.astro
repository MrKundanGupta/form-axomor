---
import Layout from '../layouts/Layout.astro';
import ResultsChart from '../components/ResultsChart.jsx';
---

<Layout title="30 Hajo Sualkuchi Survey | Results Dashboard">
  <!-- Breadcrumb / Navigation Bar -->
  <div class="bg-[#003366] text-white text-sm py-2 px-4 shadow-sm">
    <div class="max-w-5xl mx-auto flex justify-between items-center">
      <div class="flex space-x-2">
        <span>Home</span>
        <span>&raquo;</span>
        <span class="font-semibold text-[#FF9933]">Constituency Survey (30 Hajo Sualkuchi)</span>
      </div>
      <a href={import.meta.env.BASE_URL} class="hover:underline text-xs bg-white text-[#003366] px-2 py-1 rounded">
        Start New Entry
      </a>
    </div>
  </div>

  <main class="max-w-5xl mx-auto px-4 py-6">
    <ResultsChart client:load />
  </main>
</Layout>
